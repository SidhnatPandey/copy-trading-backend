{
  "info": {
    "_postman_id": "copy-trading-api",
    "name": "Copy Trading Backend API",
    "description": "API collection for testing Copy Trading Backend endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "1"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Sign Up",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"TestPassword123\",\n  \"username\": \"testuser\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/signup",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "auth",
                "signup"
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set(\"TOKEN\", jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"TestPassword123\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/login",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/users/{{USER_ID}}",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "users",
                "{{USER_ID}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Trades",
      "item": [
        {
          "name": "Create Trade",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{USER_ID}}\",\n  \"symbol\": \"BTCUSD\",\n  \"side\": \"BUY\",\n  \"amount\": 0.5,\n  \"price\": 45000,\n  \"status\": \"OPEN\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/trades",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "trades"
              ]
            }
          }
        },
        {
          "name": "Get Trade History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/trades/history/{{USER_ID}}",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "trades",
                "history",
                "{{USER_ID}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Copy Trading",
      "item": [
        {
          "name": "Start Copy Trading",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"follower_id\": \"{{FOLLOWER_ID}}\",\n  \"trader_id\": \"{{TRADER_ID}}\",\n  \"allocation\": 5000\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/copy/start",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "copy",
                "start"
              ]
            }
          }
        },
        {
          "name": "Stop Copy Trading",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"follower_id\": \"{{FOLLOWER_ID}}\",\n  \"trader_id\": \"{{TRADER_ID}}\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/copy/stop",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "copy",
                "stop"
              ]
            }
          }
        },
        {
          "name": "Get Followers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/copy/followers/{{TRADER_ID}}",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "copy",
                "followers",
                "{{TRADER_ID}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Leaderboard",
      "item": [
        {
          "name": "Get Leaderboard",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/leaderboard",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "leaderboard"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Market",
      "item": [
        {
          "name": "Get BTC Price",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/market/btc",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "market",
                "btc"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "TOKEN",
      "value": ""
    },
    {
      "key": "USER_ID",
      "value": ""
    },
    {
      "key": "TRADER_ID",
      "value": ""
    },
    {
      "key": "FOLLOWER_ID",
      "value": ""
    }
  ]
}
